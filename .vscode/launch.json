{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Express Server",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/server/dist/app.js",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "name": "Launch React Client",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [ "run", "dev" ],
            "runtimeExecutable": "npm",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/client/my-app",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "cwd": "${workspaceFolder}/client/my-app"
        },
        {
            "name": "Debug Server Jasmine Tests",
            "type": "node",
            "program": "${workspaceFolder}/server/node_modules/jasmine/bin/jasmine.js",
            "request": "launch",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/server",
            "skipFiles": [
                "<node_internals>/**"
            ]

        },
        {
            "name": "Debug Jasmine Current File",
            "type": "node",
            "program": "${workspaceFolder}/server/node_modules/jasmine/bin/jasmine.js",
            "args": ["${workspaceFolder}/${relativeFileDirname}/${fileBasenameNoExtension}.js"],
            "request": "launch",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}